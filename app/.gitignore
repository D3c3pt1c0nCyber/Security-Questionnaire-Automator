# ==============================================================
# SECRETS & CREDENTIALS — never commit these
# ==============================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
*.csr
secrets/
credentials/

# ==============================================================
# UPLOADED FILES — may contain sensitive security documents
# ==============================================================
uploads/*
!uploads/.gitkeep

# ==============================================================
# GENERATED OUTPUT FILES
# ==============================================================
output/
*.xlsx
*.docx
*.pdf
*.csv
temp/
tmp/

# ==============================================================
# NODE
# ==============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm

# ==============================================================
# RUNTIME DATA — may contain credentials/hashes/PII
# ==============================================================
data/users.json
data/activity-logs.json

# ==============================================================
# LOGS — may contain tokens/keys in request logs
# ==============================================================
*.log
logs/
*.log.*

# ==============================================================
# OS & EDITOR NOISE
# ==============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
